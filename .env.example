APP_NAME="Family Tree Premium"
APP_ENV=production
APP_KEY=
# ВСТАВЬТЕ ВРУЧНУЮ: основной URL сайта (https://your-domain.com)
APP_URL=https://example.com
# ВСТАВЬТЕ ВРУЧНУЮ: включайте false в production
APP_DEBUG=false

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ВСТАВЬТЕ ВРУЧНУЮ: БД строго MySQL
DB_CONNECTION=mysql
# ВСТАВЬТЕ ВРУЧНУЮ: хост MySQL (обычно localhost на shared hosting)
DB_HOST=127.0.0.1
DB_PORT=3306
# ВСТАВЬТЕ ВРУЧНУЮ: имя БД
DB_DATABASE=family_tree_premium
# ВСТАВЬТЕ ВРУЧНУЮ: пользователь БД
DB_USERNAME=family_tree_user
# ВСТАВЬТЕ ВРУЧНУЮ: пароль БД
DB_PASSWORD=change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# ВСТАВЬТЕ ВРУЧНУЮ: private/public диски; на shared hosting достаточно local/public
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ВСТАВЬТЕ ВРУЧНУЮ: SMTP провайдера
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=change_me
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ВСТАВЬТЕ ВРУЧНУЮ: если S3 не используется, оставить пустым
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
